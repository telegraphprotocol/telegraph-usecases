# Telegraph subnet dispatcher (must use port 7044 — port 80 is nginx UI and returns 405)
TELEGRAPH_BASE_URL=http://54.252.48.30:7044
TELEGRAPH_REQUEST_TIMEOUT_MS=30000

# Subnet paths
BITMIND_SUBNET_PREFIX=/subnet-dispatcher/v1/34
ITSAI_SUBNET_PREFIX=/subnet-dispatcher/v1/32

# x402 Solana payment (server-side keypair, base58-encoded)
SOLANA_PRIVATE_KEY=
SOLANA_NETWORK=devnet
# Set to "1" to log response headers when no settlement header is found (debug BitMind/ItsAI proofs)
DEBUG_X402=

# Google Ads REST API
# Developer token from https://developers.google.com/google-ads/api/docs/first-call/dev-token
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_BASE_URL=https://googleads.googleapis.com
# Set to "true" to simulate campaign pausing without calling Google Ads API
GOOGLE_ADS_SIMULATE=true

# Content extraction
CONTENT_FETCH_TIMEOUT_MS=10000
CONTENT_MAX_IMAGES=5

# CORS (comma-separated origins; blank = allow all)
FRONTEND_ORIGIN=

# HTTP
PORT=3001
