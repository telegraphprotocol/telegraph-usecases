PORT=5000
DATABASE_URL="mongodb://localhost:27017/sniper_bot?directConnection=true"
JWT_SECRET="replace-with-jwt-secret"
MASTER_ENCRYPTION_KEY="replace-with-64-char-hex-key"

# Subscription / billing verification (Polygon Amoy testnet)
SUBSCRIPTION_CHAIN_ID=80002
POLYGON_RPC_URL="https://rpc-amoy.polygon.technology"
POLYGON_USDC_CONTRACT_ADDRESS="0xYourAmoyTokenAddress"
POLYGON_USDC_DECIMALS=6
SUBSCRIPTION_TREASURY_WALLET="0xYourTreasuryWalletAddress"

# x402 payment key — used by the server to pay Telegraph API calls via Solana
# Wallet must hold USDC on Solana, ~0.01 USDC per call
# Base-58 encoded private key (same format as Phantom wallet export)
SOLANA_PRIVATE_KEY="YourBase58SolanaPrivateKey"

# Market monitor pipeline
TELEGRAPH_BASE_URL="http://54.252.48.30:7044"
MARKET_MONITOR_KEYWORDS="Fuel Prices,Global Conflict,Strait of Hormuz"
MARKET_FETCH_LIMIT=3
MARKET_FETCH_CANDIDATE_LIMIT=30
TELEGRAPH_NEWS_CALL_DELAY_MS=1200
TELEGRAPH_NEWS_RETRY_MAX_ATTEMPTS=2
TELEGRAPH_NEWS_RETRY_BASE_DELAY_MS=1000
