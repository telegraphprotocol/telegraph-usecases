# Copy to `.env` in this directory (`frontend/`). Vite exposes only variables prefixed with `VITE_`.
# Used by `src/solana/devnet.js` for the dashboard wallet (devnet SOL + USDC).

# Optional: custom Solana devnet RPC (recommended for production-like dev: Helius, QuickNode, etc.)
VITE_SOLANA_RPC_URL=https://api.devnet.solana.com

# Optional: override devnet USDC SPL mint (default is Circle devnet USDC)
VITE_DEVNET_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# Optional: backend API base URL for deployed frontend (leave empty in local dev to use Vite /api proxy)
# Example: https://truthwire-backend.onrender.com
VITE_API_BASE_URL=
