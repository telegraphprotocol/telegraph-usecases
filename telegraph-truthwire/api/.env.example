# Loaded automatically on startup (see src/server.ts + src/loadLocalEnv.ts).
# Do not commit real secrets; copy to `.env` and fill in locally.

# vxTwitter public API (no auth required)
VX_API_BASE=https://api.vxtwitter.com

# Telegraph subnet-dispatcher (BitMind 34 + ItsAI 32). Use :7044 — port 80 is nginx and returns 405 for POST /subnet-dispatcher/...
TELEGRAPH_BASE_URL=http://54.252.48.30:7044

BITMIND_SUBNET_PREFIX=/subnet-dispatcher/v1/34
ITSAI_SUBNET_PREFIX=/subnet-dispatcher/v1/32

# Timeouts (ms). If unset, TELEGRAPH_REQUEST_TIMEOUT_MS defaults to 30000 and is used for ItsAI;
# BITMIND_REQUEST_TIMEOUT_MS falls back to TELEGRAPH_REQUEST_TIMEOUT_MS.
TELEGRAPH_REQUEST_TIMEOUT_MS=30000
BITMIND_REQUEST_TIMEOUT_MS=
ITSAI_REQUEST_TIMEOUT_MS=

PORT=3000

# Optional frontend origin(s) for CORS (comma-separated). Example:
# FRONTEND_ORIGIN=https://adorable-dasik-1e04c1.netlify.app
# FRONTEND_ORIGIN=https://adorable-dasik-1e04c1.netlify.app,https://truthwire.app
FRONTEND_ORIGIN=

# Optional: set to verbatim to use default DNS ordering (default in app: ipv4first for fewer fetch failures).
# DNS_RESULT_ORDER=verbatim

# x402 Solana payment signing (admin key — used server-side to pay Telegraph subnet fees)
SOLANA_PRIVATE_KEY=
USDC_ADDRESS=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
# Set to "mainnet" for production; defaults to "devnet"
SOLANA_NETWORK=devnet

# When X API fetch fails, check the terminal running `npm run dev` for lines starting with:
#   [x-news-verifier][X_API]
